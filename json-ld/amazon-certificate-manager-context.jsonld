{
  "@context": {
    "@version": 1.1,
    "acm": "https://docs.aws.amazon.com/acm/latest/APIReference/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Certificate": {
      "@id": "acm:Certificate",
      "@context": {
        "certificateArn": "acm:certificateArn",
        "domainName": "schema:name",
        "subjectAlternativeNames": {
          "@id": "acm:subjectAlternativeNames",
          "@container": "@set"
        },
        "status": "acm:status",
        "type": "acm:certificateType",
        "issuer": "acm:issuer",
        "serial": "acm:serial",
        "keyAlgorithm": "acm:keyAlgorithm",
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "issuedAt": {
          "@id": "acm:issuedAt",
          "@type": "xsd:dateTime"
        },
        "notBefore": {
          "@id": "acm:notBefore",
          "@type": "xsd:dateTime"
        },
        "notAfter": {
          "@id": "acm:notAfter",
          "@type": "xsd:dateTime"
        }
      }
    },

    "DomainValidation": {
      "@id": "acm:DomainValidation",
      "@context": {
        "domainName": "schema:name",
        "validationDomain": "acm:validationDomain",
        "validationStatus": "acm:validationStatus",
        "validationMethod": "acm:validationMethod"
      }
    }
  }
}
